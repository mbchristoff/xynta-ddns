# Copy this file to .env and fill in your values.
# .env is excluded from git to prevent secrets from leaking.

# Required: your Xynta HostFact UserID
DDNS_XYNTA_API_USER_ID=your-user-id

# Required: IP-hash (API key) from your Xynta HostFact account
DDNS_XYNTA_API_IP_HASH=your-ip-hash

# Optional overrides (defaults shown):
# DDNS_XYNTA_API_URL=https://api.xynta.com/
# DDNS_CONFIG_FILE=/app/config.yml
# DDNS_VERBOSE=false
